{
  "expo": {
    "name": "aiFATandYOU",
    "slug": "ai-fat-and-you",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aifatandyou",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aifatandyou.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow aiFATandYOU to access your photo library to scan food."
      }
    },
    "android": {
      "package": "com.aifatandyou.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A1A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow aiFATandYOU to access your camera to scan food."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
